#include <stdio.h>
#include <stdlib.h>
#include "fila.h"


struct fila_t *fila_cria ()
{
    // Aloca a estrutura da fila
    struct fila_t *f = malloc(sizeof(struct fila_t));
    if (!f)
        return NULL;

    f->prim = NULL;
    f->ult = NULL;
    f->num = 0;

    return f;
}

struct fila_t *fila_destroi (struct fila_t *f)
{
    if (!f)
        return NULL;

    struct fila_nodo_t *atual;
    atual = f->prim;
    struct fila_nodo_t *prox;

    while (atual)
    {
        prox = atual->prox;
        
        free(atual);
        
        atual = prox;
    }

    free(f);
    return NULL;
}

int fila_insere (struct fila_t *f, int item)
{
    if (!f)
        return 0;

    struct fila_nodo_t *novo;
    novo = malloc(sizeof(struct fila_nodo_t));

    if (!novo)
        return 0;

    novo->item = item;
    novo->prox = NULL;

    
    if (f->prim == NULL)
    {
        f->prim = novo;
        f->ult  = novo;
    }
    else
    {
        f->ult->prox = novo; 
	f->ult = novo; 
    }

    f->num++;
    return 1;
}

int fila_retira (struct fila_t *f, int *item)
{
    if (!f || f->prim == NULL || !item)
        return 0;

    struct fila_nodo_t *removido;
    removido = f->prim;
	
	*item = removido->item;
	
	f->prim = removido->prox;

	if (f->prim == NULL)
		f->ult == NULL;
	
	f->num--;
	free(removido);
	
	return 1;
}

int fila tamanho (struct fila_t *f)
{
	if(!f)
		return -1;

	return f->num;
}


