#include <stdio.h>
#include <string.h>

#define TAM_MAX_PALAVRAS 5000 

// =========================================================================
// PERGUNTA 1: Como os dados serão representados na memória? 
// Resposta: Usando uma 'struct' que une o texto da palavra e sua contagem,
// e criando um array (vetor) dessas structs na função main.
// =========================================================================
struct Palavra {
    char texto[100]; // Limite de 100 caracteres exigido no exercício
    int frequencia;
};

int main() {
    char nome_arquivo[100];
    FILE *arquivo;
    
    printf("Digite o nome do arquivo de texto: ");
    scanf("%99s", nome_arquivo);

    // =========================================================================
    // PERGUNTA 2: Como o programa vai acessar os dados externos?
    // Resposta: Usando um ponteiro FILE* e a função fopen() no modo de 
    // leitura ("r"), além de verificar se o arquivo realmente existe.
    // =========================================================================
    arquivo = fopen(nome_arquivo, "r");
    if (arquivo == NULL) {
        printf("Erro ao abrir o arquivo.\n");
        return 1;
    }

    struct Palavra dicionario[TAM_MAX_PALAVRAS];
    int total_palavras_distintas = 0;
    char buffer[100];

    // =========================================================================
    // PERGUNTA 3: Como eu extraio o texto do arquivo?
    // Resposta: Lendo palavra por palavra com fscanf() até encontrar o 
    // fim do arquivo (EOF - End Of File).
    // =========================================================================
    while (fscanf(arquivo, "%99s", buffer) != EOF && total_palavras_distintas < TAM_MAX_PALAVRAS) {
        int encontrada = 0;
        
        // =====================================================================
        // PERGUNTA 4: O que eu faço com cada palavra extraída?
        // Resposta: Procuro no vetor. Se já existir, somo 1 na frequência.
        // Se for nova, adiciono ao final do vetor com frequência 1.
        // =====================================================================
        for (int i = 0; i < total_palavras_distintas; i++) {
            if (strcmp(dicionario[i].texto, buffer) == 0) {
                dicionario[i].frequencia++;
                encontrada = 1;
                break;
            }
        }
        
        if (!encontrada) {
            strcpy(dicionario[total_palavras_distintas].texto, buffer);
            dicionario[total_palavras_distintas].frequencia = 1;
            total_palavras_distintas++;
        }
    }

    // =========================================================================
    // PERGUNTA 5: Como eu encerro a comunicação com o arquivo?
    // Resposta: Usando fclose() para liberar os recursos do sistema.
    // =========================================================================
    fclose(arquivo);

    // =========================================================================
    // PERGUNTA 6: Como encontro a resposta que o exercício pede?
    // Resposta: Percorrendo o vetor preenchido para achar o maior valor 
    // de frequência e imprimindo a palavra correspondente na tela.
    // =========================================================================
    int max_freq = 0;
    char palavra_vencedora[100] = "";

    for (int i = 0; i < total_palavras_distintas; i++) {
        // O uso do '>' garante que o primeiro empate a chegar no topo seja mantido
        if (dicionario[i].frequencia > max_freq) {
            max_freq = dicionario[i].frequencia;
            strcpy(palavra_vencedora, dicionario[i].texto);
        }
    }

    // Apresentação do resultado
    if (total_palavras_distintas > 0) {
        printf("\nA palavra mais frequente e: '%s' com %d ocorrencias.\n", palavra_vencedora, max_freq);
    } else {
        printf("\nO arquivo esta vazio ou nao contem palavras validas.\n");
    }

    return 0;
}
