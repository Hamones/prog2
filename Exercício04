#include <stdio.h>
#include <string.h>

#define TAM_MAX_PALAVRAS 5000 // Limite de palavras distintas para armazenar

// Estrutura para mapear a palavra e sua contagem
struct Palavra {
    char texto[100]; // "Nenhuma palavra terá mais do que 100 caracteres"
    int frequencia;
};

int main() {
    char nome_arquivo[100];
    FILE *arquivo;
    
    // 1. Receber o nome do arquivo
    printf("Digite o nome do arquivo de texto: ");
    scanf("%99s", nome_arquivo);

    // 2. Abrir o arquivo no modo de leitura ("r")
    arquivo = fopen(nome_arquivo, "r");
    if (arquivo == NULL) {
        printf("Erro ao abrir o arquivo.\n");
        return 1;
    }

    struct Palavra dicionario[TAM_MAX_PALAVRAS];
    int total_palavras_distintas = 0;
    char buffer[100];

    // 3. Fazer a varredura lendo palavra por palavra
    // fscanf retorna EOF quando atinge o fim do arquivo
    while (fscanf(arquivo, "%99s", buffer) != EOF && total_palavras_distintas < TAM_MAX_PALAVRAS) {
        int encontrada = 0;
        
        // Verifica se a palavra lida já existe no nosso vetor
        for (int i = 0; i < total_palavras_distintas; i++) {
            if (strcmp(dicionario[i].texto, buffer) == 0) {
                dicionario[i].frequencia++;
                encontrada = 1;
                break;
            }
        }
        
        // Se não foi encontrada, adiciona como uma nova palavra
        if (!encontrada) {
            strcpy(dicionario[total_palavras_distintas].texto, buffer);
            dicionario[total_palavras_distintas].frequencia = 1;
            total_palavras_distintas++;
        }
    }

    // 4. Fechar o arquivo após o uso, como recomendado na aula
    fclose(arquivo);

    // 5. Encontrar a palavra mais frequente
    int max_freq = 0;
    char palavra_vencedora[100] = "";

    for (int i = 0; i < total_palavras_distintas; i++) {
        if (dicionario[i].frequencia > max_freq) {
            max_freq = dicionario[i].frequencia;
            strcpy(palavra_vencedora, dicionario[i].texto);
        }
    }

    // 6. Apresentar o resultado
    if (total_palavras_distintas > 0) {
        printf("\nA palavra mais frequente é: '%s' com %d ocorrencias.\n", palavra_vencedora, max_freq);
    } else {
        printf("\nO arquivo esta vazio ou nao contem palavras validas.\n");
    }

    return 0;
}
